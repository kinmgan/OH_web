# ==========================================
# CẤU HÌNH BÍ MẬT (SECRETS ENVIRONMENT)
# Copy file này thành ".env" và điền các thông tin thực tế vào.
# KHÔNG BAO GIỜ commit file ".env" lên git!
# ==========================================

# 1. Database
DB_USERNAME=postgres
DB_PASSWORD=your_secure_db_password_here

# 2. Security / JWT
# Tạo một chuỗi ngẫu nhiên dài (ít nhất 32 ký tự) làm JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRATION=86400000

# 3. Gemini AI API Keys
# Danh sách các key cách nhau bằng dấu phẩy, KHÔNG có khoảng trắng
GEMINI_API_KEYS=key1,key2,key3
# Bật/tắt toàn bộ AI features (chatbot + review analysis)
GEMINI_ENABLED=true
# Bật/tắt phân tích review bằng AI (tốn quota riêng)
GEMINI_REVIEW_AI_ENABLED=true

# 4. Email (Brevo)
BREVO_SMTP_LOGIN=your_brevo_login
BREVO_SMTP_KEY=your_brevo_smtp_key

# 5. Payment Gateways (Ví dụ VNPay)
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret

# (Thêm các cấu hình nhạy cảm khác nếu có)
